# /etc/pa-system/pa.env
# PA System Controller — Environment Configuration
# --------------------------------------------------
# Edit this file to configure the MQTT broker and audio settings.
# Changes take effect after: sudo systemctl restart pa-controller

# MQTT Broker (your edge AI server IP)
PA_MQTT_BROKER=192.168.1.100
PA_MQTT_PORT=1883
PA_MQTT_TOPIC=pa/command
PA_MQTT_STATUS_TOPIC=pa/status
PA_MQTT_CLIENT_ID=pi-pa-controller

# MQTT Authentication (leave blank if no auth)
PA_MQTT_USER=
PA_MQTT_PASS=

# Audio Volumes (0-100)
PA_DEFAULT_VOLUME=85
PA_SIREN_VOLUME=100

# Siren loop count (how many times to repeat the siren file)
PA_SIREN_REPEAT=3

# Resume BGM after siren finishes? (true/false)
PA_RESUME_AFTER_SIREN=false

# Logging level (DEBUG, INFO, WARNING, ERROR)
PA_LOG_LEVEL=INFO
