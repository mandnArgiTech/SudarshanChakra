# API (default: /api/v1 — proxied to api-gateway in dev)
# VITE_API_BASE_URL=/api/v1

# Optional: edge node Flask GUI — enables camera thumbnails + live JPEG in dashboard
# Must be reachable from the browser (same LAN/VPN). Camera IDs must match device-service.
# VITE_EDGE_SNAPSHOT_BASE=http://192.168.68.50:5000
