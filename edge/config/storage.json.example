{
    "ssd_pools": [
        {
            "path": "/data/video",
            "cameras": ["cam-01", "cam-02"]
        }
    ],
    "retention_days": 10,
    "segment_seconds": 600,
    "high_watermark_percent": 85,
    "archive": {
        "enabled": false,
        "path": "/archive/video"
    },
    "test_camera": {
        "id": "cam-test-01",
        "name": "Optional integration-test camera",
        "rtsp_url": "rtsp://USER:PASS@CAMERA_IP:554/stream2",
        "stream1_url": "rtsp://USER:PASS@CAMERA_IP:554/stream1"
    }
}
