# ==============================================================================
# SudarshanChakra Cloud VPS — Environment Variables
# ==============================================================================
# Copy this to .env and fill in real values before running docker-compose

# PostgreSQL
DB_USER=scadmin
DB_PASS=CHANGE_ME_TO_STRONG_PASSWORD

# RabbitMQ
RABBITMQ_USER=admin
RABBITMQ_PASS=CHANGE_ME_TO_STRONG_PASSWORD

# JWT Secret (generate with: openssl rand -hex 32)
JWT_SECRET=CHANGE_ME_64_CHAR_HEX_STRING

# Edge MQTT credentials
MQTT_EDGE_PASS=CHANGE_ME_EDGE_PASSWORD
